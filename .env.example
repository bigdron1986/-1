# Настройки почты для загрузки отчётов термометрии
# Скопируйте этот файл в .env и заполните свои данные
# При сборке exe: .env должен лежать рядом с exe-файлом

EMAIL_LOGIN=example@yandex.ru
EMAIL_PASSWORD=ваш_пароль_приложения
EMAIL_IMAP_SERVER=imap.yandex.ru
EMAIL_IMAP_PORT=993
EMAIL_SENDER=ams10@aminosib.ru
EMAIL_DAYS_BACK=30
